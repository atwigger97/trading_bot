# prediction-bot/.env.example
# Copy this to .env and fill in your credentials. Never commit .env to git.

# ─── POLYMARKET ───────────────────────────────────────────────────────────────
# Get from: https://docs.polymarket.com/#authentication
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_WALLET_ADDRESS=       # Your Polygon wallet address
POLYMARKET_PRIVATE_KEY=          # ⚠️  Keep this VERY safe. Use a dedicated trading wallet.

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── TWITTER / X ─────────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
# Basic plan (~$100/mo) gives 500k tweets/month — enough for this bot
TWITTER_BEARER_TOKEN=

# ─── REDDIT ──────────────────────────────────────────────────────────────────
# Get from: https://www.reddit.com/prefs/apps (free, instant)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=prediction-bot/1.0

# ─── BOT SETTINGS ────────────────────────────────────────────────────────────
DB_PATH=data/prediction_bot.db
LOG_LEVEL=INFO

# ─── RISK OVERRIDES (optional — defaults set in config.py) ───────────────────
# KELLY_FRACTION=0.25
# MAX_SINGLE_POSITION_USDC=500
# MAX_TOTAL_EXPOSURE_USDC=2000
# DAILY_LOSS_LIMIT_USDC=300
